<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vd="clr-namespace:LearnEnglishVocab.Model"
             x:Class="LearnEnglishVocab.View.HomePage"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}"
             Title="HomePage">
    <!-- Główna siatka dzieląca ekran na sekcje z rysunku -->
    <Grid RowDefinitions="250, 220, *, 80" ColumnDefinitions="*" >

        <Grid Grid.Row="0" 
      ColumnDefinitions="*, Auto" 
      Padding="20,50,20,20" 
      BackgroundColor="#4A90E2">

            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="Cześć, User!" 
               TextColor="White" 
               FontSize="24" 
               FontAttributes="Bold" />
                <Label Text="Miłego dnia" 
               TextColor="#D1E4FF" 
               FontSize="14" />
            </VerticalStackLayout>

            <Label Grid.Column="1" 
           Text="12:45" 
           TextColor="White" 
           FontSize="28" 
           FontAttributes="Bold" 
           VerticalOptions="Center" 
           HorizontalOptions="End" />
        </Grid>

        <!-- #Tło 2: Karuzela Kursów Językowych -->
        <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="10">
            <Label Text="Twoje Kursy" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   Margin="10,0" 
                   TextColor="#2D3436"/>

            <CarouselView ItemsSource="{Binding LastSeen}" PeekAreaInsets="35" Loop="False">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="vd:Course">
                        <Border StrokeShape="RoundRectangle 20" 
                                BackgroundColor="White" 
                                Margin="10" 
                                Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto, Auto, Auto, *" ColumnDefinitions="*, Auto">
                                <!-- Nazwa Języka -->
                                <Label Text="{Binding courseName}" 
                                       FontSize="22" 
                                       FontAttributes="Bold" 
                                       Grid.Column="0"/>

                                <!-- Flaga -->
                                <Image Source="{Binding imagePath}"
                                       HeightRequest="30" 
                                       Grid.Column="1" 
                                       VerticalOptions="Start"/>

                                <!-- Stopień zaawansowania (Gwiazdki) -->
                                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10" Spacing="2">
                                    <Label Text="{Binding level}" VerticalOptions="Center" Margin="0,0,10,0" FontAttributes="Bold" TextColor="#4A90E2"/>
                                    <!-- Przykład 6 gwiazdek -->
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="☆" FontSize="20" TextColor="#BDC3C7"/>
                                    <Label Text="☆" FontSize="20" TextColor="#BDC3C7"/>
                                </HorizontalStackLayout>

                                <!-- Przycisk Przejścia -->
                                <Button Grid.Row="3" 
                                        Grid.ColumnSpan="2" 
                                        Text="Kontynuuj naukę" 
                                        CornerRadius="10" 
                                        BackgroundColor="#4A90E2" 
                                        TextColor="White"
                                        VerticalOptions="End"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
        </VerticalStackLayout>

        <!-- Sekcja Środkowa (Dla Ciebie - Siatka kafelków) -->
        <CollectionView Grid.Row="2" 
                ItemsSource="{Binding AllCourses}"
                SelectionMode="Single"
                SelectionChangedCommand="{Binding onSelectedItemCommand}"
                Margin="10,0"
                SelectedItem="{Binding SelectedItem}">

            <CollectionView.Header>
                <Label Text="Odkrywaj nowe tematy" 
               FontSize="18" 
               FontAttributes="Bold" 
               Padding="10,10,10,15" 
               TextColor="#2D3436"/>
            </CollectionView.Header>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                         Span="2" 
                         HorizontalItemSpacing="10" 
                         VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vd:Course">
                    <Border StrokeShape="RoundRectangle 15" 
                    BackgroundColor="White"
                    Padding="15"
                    HeightRequest="140">

                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                            <Image Source="{Binding imagePath}" 
                           HeightRequest="40" 
                           HorizontalOptions="Start"/>

                            <Label Text="{Binding courseName}" 
                           FontSize="16" 
                           FontAttributes="Bold" 
                           TextColor="#2D3436"
                           MaxLines="1" 
                           LineBreakMode="TailTruncation"/>

                            <Label Text="{Binding level}" 
                           FontSize="12" 
                           TextColor="#4A90E2" 
                           FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="40" Color="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <!-- Bottom Menu -->
        <Border Grid.Row="3" 
        BackgroundColor="White" 
        Padding="10,5" 
        StrokeThickness="0"
        HeightRequest="70">
            <Grid ColumnDefinitions="*, *, *">
                <ImageButton Source="home_icon.png" Grid.Column="0" Aspect="AspectFit" Margin="5"/>

                <!-- Centralny przycisk Plus -->
                <Border Grid.Column="1" 
                WidthRequest="50" 
                HeightRequest="50" 
                StrokeShape="RoundRectangle 25"
                BackgroundColor="#00AEEF"
                VerticalOptions="Center"
                StrokeThickness="0">
                    <Label Text="+" 
                   TextColor="White" 
                   FontSize="30" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"
                   Margin="0,0,0,2"/>
                </Border>

                <ImageButton Source="settings_icon.png" Grid.Column="2" Aspect="AspectFit" Margin="5"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>