<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearnEnglishVocab.View.HomePage"
             BackgroundColor="#F5F6FA"
             Title="HomePage">
    <!-- Główna siatka dzieląca ekran na sekcje z rysunku -->
    <Grid RowDefinitions="250, 220, *, 80" ColumnDefinitions="*">

        <Grid Grid.Row="0" 
      ColumnDefinitions="*, Auto" 
      Padding="20,50,20,20" 
      BackgroundColor="#4A90E2">

            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="Cześć, User!" 
               TextColor="White" 
               FontSize="24" 
               FontAttributes="Bold" />
                <Label Text="Miłego dnia" 
               TextColor="#D1E4FF" 
               FontSize="14" />
            </VerticalStackLayout>

            <Label Grid.Column="1" 
           Text="12:45" 
           TextColor="White" 
           FontSize="28" 
           FontAttributes="Bold" 
           VerticalOptions="Center" 
           HorizontalOptions="End" />
        </Grid>

        <!-- #Tło 2: Karuzela Kursów Językowych -->
        <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="10">
            <Label Text="Twoje Kursy" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   Margin="10,0" 
                   TextColor="#2D3436"/>

            <CarouselView x:Name="CoursesCarousel" PeekAreaInsets="35">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 20" 
                                BackgroundColor="White" 
                                Margin="10" 
                                Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto, Auto, Auto, *" ColumnDefinitions="*, Auto">
                                <!-- Nazwa Języka -->
                                <Label Text="Angielski" 
                                       FontSize="22" 
                                       FontAttributes="Bold" 
                                       Grid.Column="0"/>

                                <!-- Flaga -->
                                <Image Source="uk_flag.png" 
                                       HeightRequest="30" 
                                       Grid.Column="1" 
                                       VerticalOptions="Start"/>

                                <!-- Stopień zaawansowania (Gwiazdki) -->
                                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10" Spacing="2">
                                    <Label Text="B2" VerticalOptions="Center" Margin="0,0,10,0" FontAttributes="Bold" TextColor="#4A90E2"/>
                                    <!-- Przykład 6 gwiazdek -->
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="★" FontSize="20" TextColor="#F1C40F"/>
                                    <Label Text="☆" FontSize="20" TextColor="#BDC3C7"/>
                                    <Label Text="☆" FontSize="20" TextColor="#BDC3C7"/>
                                </HorizontalStackLayout>

                                <!-- Przycisk Przejścia -->
                                <Button Grid.Row="3" 
                                        Grid.ColumnSpan="2" 
                                        Text="Kontynuuj naukę" 
                                        CornerRadius="10" 
                                        BackgroundColor="#4A90E2" 
                                        TextColor="White"
                                        VerticalOptions="End"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
        </VerticalStackLayout>

        <!-- Sekcja Środkowa (Dla Ciebie - Siatka kafelków) -->
        <ScrollView Grid.Row="2" Padding="20">
            <VerticalStackLayout Spacing="15">
                <Label Text="Dla Ciebie" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>

                <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween">
                    <!-- Przykładowe kafelki z Twojego rysunku -->
                    <Border WidthRequest="160" HeightRequest="100" StrokeShape="RoundRectangle 15" BackgroundColor="#E0E0E0" Margin="0,5"/>
                    <Border WidthRequest="160" HeightRequest="100" StrokeShape="RoundRectangle 15" BackgroundColor="#E0E0E0" Margin="0,5"/>
                    <Border WidthRequest="160" HeightRequest="100" StrokeShape="RoundRectangle 15" BackgroundColor="#E0E0E0" Margin="0,5"/>
                </FlexLayout>

                <!-- Pagynacja / Kropki pod sekcją -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10">
                    <Ellipse WidthRequest="8" HeightRequest="8" Fill="#4A90E2"/>
                    <Ellipse WidthRequest="8" HeightRequest="8" Fill="#BDC3C7"/>
                    <Ellipse WidthRequest="8" HeightRequest="8" Fill="#BDC3C7"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- #Tło 3: Dolny pasek nawigacji z przyciskiem (+) -->
        <Border Grid.Row="3" 
                BackgroundColor="White" 
                StrokeShape="RoundRectangle 0" 
                VerticalOptions="End">
            <Grid ColumnDefinitions="*, *, *">
                <ImageButton Source="user_profile.png" HeightRequest="30" Grid.Column="0"/>

                <!-- Przycisk (+) - Wyśrodkowany i lekko uniesiony -->
                <Button Grid.Column="1" 
                        Text="+" 
                        FontSize="30" 
                        TextColor="White"
                        BackgroundColor="#4A90E2" 
                        WidthRequest="70" 
                        HeightRequest="70" 
                        CornerRadius="35"
                        TranslationY="-20">
                    <Button.Shadow>
                        <Shadow Brush="#4A90E2" Offset="0,10" Radius="15" Opacity="0.4"/>
                    </Button.Shadow>
                </Button>

                <ImageButton Source="feed_icon.png" HeightRequest="30" Grid.Column="2"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>