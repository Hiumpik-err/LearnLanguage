<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearnEnglishVocab.View.Registration"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}"
             Title="Rejestracja">
    <ScrollView>
        <VerticalStackLayout Spacing="20" 
                             Padding="30, 40" 
                             VerticalOptions="Center">

            <!-- Nagłówek -->
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="Stwórz konto"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#333, Dark=White}"
                       HorizontalOptions="Center" />
                <Label Text="Wypełnij poniższe dane, aby dołączyć"
                       FontSize="16"
                       TextColor="Gray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Kontenery pól tekstowych -->
            <VerticalStackLayout Spacing="15" Margin="0,20,0,0">

                <!-- Imię i Nazwisko w jednym rzędzie (opcjonalnie) lub osobno -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Imię" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                            <Entry Placeholder="Jan" Text="{Binding FirstName}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Nazwisko" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                            <Entry Placeholder="Kowalski" Text="{Binding LastName}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Nazwa użytkownika -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Nazwa użytkownika" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                        <Entry Placeholder="jankowalski123" Text="{Binding Username}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Email" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                        <Entry Placeholder="przyklad@domena.pl" 
                               Keyboard="Email" 
                               Text="{Binding Emaill}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Hasło -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Hasło" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                        <Entry IsPassword="True" 
                               Placeholder="••••••••" 
                               Text="{Binding Password}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Wiek -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Wiek" FontSize="14" Margin="5,0" FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Padding="10,0">
                        <Entry Placeholder="25" 
                               Keyboard="Numeric" 
                               Text="{Binding Age}" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- Przycisk Rejestracji -->
            <Button Text="Zarejestruj się"
                    FontAttributes="Bold"
                    FontSize="18"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="55"
                    Margin="0,20,0,10"
                    Command="{Binding RegisterCommand}" />

            <!-- Link do logowania -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Masz już konto?" VerticalOptions="Center" />
                <Button Text="Zaloguj się" 
                        Variant="Text"
                        TextColor="#512BD4"
                        BackgroundColor="Transparent"
                        Padding="0" 
                        Command="{Binding GoToLoginPageCommand}"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>