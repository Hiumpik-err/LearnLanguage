<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LearnEnglishVocab.View.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Title="LoginPage">
    <Grid BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">
            <!-- Tło z delikatnym gradientem (symulowanym przez BoxView) -->
            <BoxView Color="#6366F1" Opacity="0.05" />

            <ScrollView>
                <VerticalStackLayout Padding="30, 60, 30, 30" Spacing="25" VerticalOptions="Center">

                    <!-- Logo i Powitanie -->
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,20">
                        <Border StrokeShape="RoundRectangle 24" 
                            HeightRequest="80" 
                            WidthRequest="80" 
                            BackgroundColor="#6366F1"
                            HorizontalOptions="Center">
                            <Label Text="V" 
                               FontSize="40" 
                               FontAttributes="Bold" 
                               TextColor="White" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center"/>
                        </Border>
                        <Label Text="VocabMaster" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="#1E293B" 
                           HorizontalOptions="Center"/>
                        <Label Text="Twój osobisty asystent językowy" 
                           FontSize="14" 
                           TextColor="#64748B" 
                           HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Pola Logowania -->
                    <VerticalStackLayout Spacing="15">
                        <!-- Email -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Email/Nazwa Użytkownika" FontSize="14" FontAttributes="Bold" TextColor="#334155" Margin="5,0"/>
                            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" BackgroundColor="White" HeightRequest="55">
                                <Entry Placeholder="Twój adres email" 
                                   Keyboard="Email"
                                   Margin="15,0"
                                   TextColor="#1E293B"
                                   PlaceholderColor="#94A3B8"
                                   Text="{Binding Username}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Hasło -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Hasło" FontSize="14" FontAttributes="Bold" TextColor="#334155" Margin="5,0"/>
                            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" BackgroundColor="White" HeightRequest="55">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry IsPassword="True" 
                                       Placeholder="••••••••" 
                                       Margin="15,0"
                                       TextColor="#1E293B"
                                       PlaceholderColor="#94A3B8"
                                       Text="{Binding Password}"/>
                                    <Label Grid.Column="1" Text="👁️" VerticalOptions="Center" Margin="0,0,15,0" TextColor="#64748B"/>
                                </Grid>
                            </Border>
                            <Label Text="Zapomniałeś hasła?" 
                               FontSize="12" 
                               TextColor="#6366F1" 
                               HorizontalOptions="End" 
                               Margin="0,5,5,0" 
                               FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Przycisk Zaloguj -->
                    <Button Text="ZALOGUJ SIĘ" 
                        BackgroundColor="#6366F1" 
                        Command="{Binding LoginCommand}"
                        TextColor="White" 
                        HeightRequest="55" 
                        CornerRadius="12" 
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,10,0,0">
                        <Button.Shadow>
                            <Shadow Brush="#6366F1" Offset="0,4" Radius="10" Opacity="0.3" />
                        </Button.Shadow>
                    </Button>

                    <!-- Separator -->
                    <Grid ColumnDefinitions="*, Auto, *" VerticalOptions="Center" Margin="0,10">
                        <BoxView Grid.Column="0" HeightRequest="1" Color="#E2E8F0" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text=" lub kontynuuj przez " Margin="10,0" TextColor="#94A3B8" FontSize="12"/>
                        <BoxView Grid.Column="2" HeightRequest="1" Color="#E2E8F0" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Social Login Buttons -->
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" WidthRequest="80" HeightRequest="55" BackgroundColor="White">
                            <Label Text="G" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1E293B"/>
                        </Border>
                        <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" WidthRequest="80" HeightRequest="55" BackgroundColor="White">
                            <Label Text="F" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1E293B"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Sekcja Rejestracji (KLIKALNA) -->
                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20,0,0" Spacing="5">
                        <Label Text="Nie masz konta?" TextColor="#64748B"/>
                        <Label Text="Zarejestruj się przez e-mail" 
                           FontAttributes="Bold" 
                           TextColor="#6366F1">
                            <Label.GestureRecognizers>
                                <!-- Tutaj podpinasz komendę, która otworzy stronę rejestracji -->
                                <TapGestureRecognizer Command="{Binding GoToRegistrationCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
</ContentPage>